OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.5-flash
OPENROUTER_FALLBACK_MODEL=openai/gpt-4o-mini

DATABASE_URL=

AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Google & Apple sign-in (optional — the password/OTP login always works;
# the "Continue with Google/Apple" buttons on /login only appear once BOTH
# vars for that provider are set). See the setup notes in README.md.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Resend (OTP emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@rkiza.sa

OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
