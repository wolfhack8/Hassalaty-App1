generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OtpPurpose {
  REGISTER
  LOGIN
}

enum Role {
  USER
  ADMIN
}

enum AccountType {
  PERSONAL
  COMMERCIAL
}

enum CompanyRole {
  OWNER
  EMPLOYEE
}

/// Role *within a Family* — mirrors CompanyRole's owner/employee split, kept as
/// its own enum (not folded into the platform-wide `Role`) because it expresses
/// a relationship, not a platform privilege level.
enum FamilyRole {
  PARENT
  CHILD
}

enum RewardKind {
  DIGITAL_THEME
  REAL_WORLD
}

enum RedemptionStatus {
  PENDING
  APPROVED
  REJECTED
  FULFILLED
}

enum GameType {
  COIN_CATCH
  TRIVIA
}

enum ChallengeStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

enum InsightPeriod {
  WEEKLY
  MONTHLY
}

model User {
  id              String      @id @default(cuid())
  email           String      @unique
  role            Role        @default(USER)
  accountType     AccountType @default(PERSONAL)
  emailVerifiedAt DateTime?
  passwordHash    String?
  name            Json?
  firstName       Json?
  phone           String?   @unique
  handle          String?
  tier            Json?
  locale          String    @default("en")
  image           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  otpChallenges   OtpChallenge[]
  preferences     UserPreferences?
  financeAccounts FinanceAccount[]
  virtualCard     VirtualCard?
  transactions    Transaction[]
  holdings        Holding[]
  goals           Goal[]
  bills           Bill[]
  beneficiaries   Beneficiary[]
  notifications   Notification[]
  insights        Insight[]
  balanceSnapshots BalanceSnapshot[]
  cashflowPoints  CashflowPoint[]
  spendingSlices  SpendingSlice[]
  marketPortfolio MarketPortfolio?
  conversations   Conversation[]
  auditLogs       AuditLog[]

  ownedCompany      Company?           @relation("CompanyOwner")
  companyMembership CompanyMembership?

  createdFamily             Family?               @relation("FamilyCreator")
  familyMembership          FamilyMembership?
  redeemedRewards           RedeemedReward[]      @relation("ChildRedemptions")
  resolvedRedemptions       RedeemedReward[]      @relation("ParentResolvedRedemptions")
  gameSessions              GameSession[]
  challenges                Challenge[]
  insightReportsReceived    ParentInsightReport[] @relation("ChildInsightReports")
  insightReportsGenerated   ParentInsightReport[] @relation("ParentGeneratedInsightReports")
}

model Company {
  id          String   @id @default(cuid())
  name        Json
  crNumber    String?
  currency    String   @default("SAR")
  ownerUserId String   @unique
  createdAt   DateTime @default(now())

  owner   User                @relation("CompanyOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  members CompanyMembership[]
}

model CompanyMembership {
  id         String      @id @default(cuid())
  companyId  String
  userId     String      @unique
  role       CompanyRole @default(EMPLOYEE)
  title      Json?
  canTopup   Boolean     @default(false)
  canSpend   Boolean     @default(true)
  spendLimit Float?
  createdAt  DateTime    @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([companyId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpChallenge {
  id             String     @id @default(cuid())
  identifier     String
  resolvedEmail  String
  codeHash       String
  purpose        OtpPurpose
  attempts       Int        @default(0)
  expiresAt      DateTime
  consumedAt     DateTime?
  metadata       Json?
  userId         String?
  createdAt      DateTime   @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([identifier, purpose, createdAt])
}

model UserPreferences {
  userId        String  @id
  biometric     Boolean @default(false)
  twoFactor     Boolean @default(false)
  hideBalances  Boolean @default(false)
  push          Boolean @default(true)
  emailReports  Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FinanceAccount {
  id       String @id @default(cuid())
  userId   String
  extId    String
  name     Json
  kind     String
  number   String
  balance  Float
  currency String @default("SAR")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, extId])
}

model VirtualCard {
  id              String  @id @default(cuid())
  userId          String  @unique
  extId           String
  name            Json
  holder          String
  last4           String
  expiry          String
  network         String
  kind            Json
  frozen          Boolean @default(false)
  monthlyLimit    Float
  spentThisMonth  Float

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id       String @id @default(cuid())
  userId   String
  extId    String
  merchant Json
  note     Json?
  category String
  type     String
  status   String
  method   String
  amount   Float
  date     DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, extId])
  @@index([userId, date])
}

model Holding {
  id        String @id @default(cuid())
  userId    String
  extId     String
  name      Json
  symbol    String
  kind      Json
  market    Json
  value     Float
  cost      Float
  units     Float
  dayChange Float
  color     String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, extId])
}

model Goal {
  id     String @id @default(cuid())
  userId String
  extId  String
  name   Json
  target Float
  saved  Float
  color  String
  icon   String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, extId])
}

model Bill {
  id       String   @id @default(cuid())
  userId   String
  extId    String
  biller   Json
  category String
  amount   Float
  dueDate  DateTime
  status   String
  autopay  Boolean

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, extId])
}

model Beneficiary {
  id       String  @id @default(cuid())
  userId   String
  extId    String
  name     Json
  bank     Json
  iban     String
  favorite Boolean

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, extId])
}

model Notification {
  id     String   @id @default(cuid())
  userId String
  extId  String
  type   String
  title  Json
  body   Json
  date   DateTime
  read   Boolean

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, extId])
}

model Insight {
  id         String @id @default(cuid())
  userId     String
  extId      String
  kind       String
  title      Json
  body       Json
  metric     Float?
  metricKind String?
  tone       String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, extId])
}

model BalanceSnapshot {
  id     String @id @default(cuid())
  userId String
  period String
  value  Float

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
}

model CashflowPoint {
  id      String @id @default(cuid())
  userId  String
  period  String
  income  Float
  expense Float

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
}

model SpendingSlice {
  id       String @id @default(cuid())
  userId   String
  category String
  amount   Float
  change   Float

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
}

model MarketPortfolio {
  id         String @id @default(cuid())
  userId     String @unique
  cash       Float
  positions  Json
  watchlist  Json
  orders     Json

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String        @id @default(cuid())
  userId    String
  title     String        @default("New chat")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String   @db.Text
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

/// System audit trail: logins (action "auth.login") and user actions.
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  action    String
  detail    String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([userId, createdAt])
}

// ---------------------------------------------------------------------------
// Family module — gamified financial literacy for children, monitored by
// parents. Mirrors the Company/CompanyMembership tenant pattern exactly:
// a Family is created by a PARENT (analogous to a Company's owner), and each
// member (parent or child) gets one FamilyMembership row carrying their role
// plus role-specific state (points, for a CHILD). Everything a child DOES
// with real money — Transaction, Goal, Bill, etc. — reuses the existing
// per-user finance models above; a child is a full User, same as an employee
// is a full User under a Company. Only the gamification layer is new.
// ---------------------------------------------------------------------------

model Family {
  id              String   @id @default(cuid())
  name            Json
  createdByUserId String   @unique
  createdAt       DateTime @default(now())

  creator User               @relation("FamilyCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  members FamilyMembership[]
  rewards Reward[]
}

/// One row per family member (parent or child). `userId` is unique — like
/// CompanyMembership, a person belongs to at most one family — so callers can
/// resolve a user's family role/points with a single indexed lookup.
model FamilyMembership {
  id          String     @id @default(cuid())
  familyId    String
  userId      String     @unique
  role        FamilyRole @default(CHILD)
  points      Int        @default(0)
  avatarTheme String?
  birthYear   Int?
  createdAt   DateTime   @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([familyId])
}

/// Reward catalog entry. `familyId = null` marks a global/default reward
/// available to every family; a non-null `familyId` is a parent-authored,
/// family-specific reward (e.g. a pre-approved real-world reward).
model Reward {
  id          String     @id @default(cuid())
  familyId    String?
  title       Json
  description Json?
  pointsCost  Int
  kind        RewardKind @default(DIGITAL_THEME)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())

  family   Family?          @relation(fields: [familyId], references: [id], onDelete: Cascade)
  redeemed RedeemedReward[]

  @@index([familyId])
}

/// A child's redemption request against the reward catalog. Points are
/// deducted (and can be refunded on rejection) by the server action that
/// transitions `status`, never by the client.
model RedeemedReward {
  id               String           @id @default(cuid())
  userId           String
  rewardId         String
  pointsCost       Int
  status           RedemptionStatus @default(PENDING)
  requestedAt      DateTime         @default(now())
  resolvedAt       DateTime?
  resolvedByUserId String?

  user       User    @relation("ChildRedemptions", fields: [userId], references: [id], onDelete: Cascade)
  resolvedBy User?   @relation("ParentResolvedRedemptions", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  reward     Reward  @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([rewardId])
}

/// One row per completed mini-game play. `pointsEarned` is the amount actually
/// credited to `FamilyMembership.points` in the same DB transaction that
/// creates this row (see `server/family/game-actions.ts`), so the two never
/// drift apart.
model GameSession {
  id           String   @id @default(cuid())
  userId       String
  gameType     GameType
  score        Int
  pointsEarned Int
  playedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, playedAt])
}

/// An AI-generated (or rule-based fallback) weekly budgeting challenge for a
/// child, e.g. "save 20 points this week by skipping the shop".
model Challenge {
  id           String          @id @default(cuid())
  userId       String
  title        String
  description  String
  targetPoints Int?
  progress     Int             @default(0)
  status       ChallengeStatus @default(ACTIVE)
  weekStart    DateTime
  weekEnd      DateTime
  aiGenerated  Boolean         @default(true)
  createdAt    DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

/// A persisted AI Parent Insights report for one child over one period. Kept
/// as rows (not recomputed on every page view) so a parent can see history,
/// and so the "generate" action stays an explicit, auditable event rather than
/// a silent background job. `locale` records which language it was written
/// in — the summary is dynamically generated prose, not a pre-translated
/// content field like the `Json` name/title fields elsewhere in this schema.
model ParentInsightReport {
  id                            String        @id @default(cuid())
  childUserId                   String
  generatedByUserId             String
  period                        InsightPeriod
  periodStart                   DateTime
  periodEnd                     DateTime
  locale                        String        @default("ar")
  summary                       String        @db.Text
  topCategory                   String?
  topCategoryPercentage         Float?
  riskLevel                     String        @default("low")
  suggestedChallengeTitle       String?
  suggestedChallengeDescription String?       @db.Text
  model                         String?
  createdAt                     DateTime      @default(now())

  child       User @relation("ChildInsightReports", fields: [childUserId], references: [id], onDelete: Cascade)
  generatedBy User @relation("ParentGeneratedInsightReports", fields: [generatedByUserId], references: [id], onDelete: Cascade)

  @@index([childUserId, period, createdAt])
}
